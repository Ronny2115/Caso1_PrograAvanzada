@model Caso1_PrograAvanzada.Entities.Habitacion

@{
    ViewData["Title"] = "Registrar Habitación";
}

<div class="card shadow">

    <div class="card-header bg-primary text-white">

        <h3 class="mb-0">
            🏨 Registrar Nueva Habitación
        </h3>

    </div>

    <div class="card-body">

        @if (ViewBag.Mensaje != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">

                @ViewBag.Mensaje

                <button class="btn-close" data-bs-dismiss="alert"></button>

            </div>
        }

        <form asp-action="Create" id="frmHabitacion">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">

                <div class="col-md-6 mb-3">

                    <label asp-for="CodigoDeHabitacion" class="form-label fw-bold"></label>

                    <input asp-for="CodigoDeHabitacion" class="form-control" />

                    <span asp-validation-for="CodigoDeHabitacion" class="text-danger"></span>

                </div>

                <div class="col-md-6 mb-3">

                    <label asp-for="NombreDeHabitacion" class="form-label fw-bold"></label>

                    <input asp-for="NombreDeHabitacion" class="form-control" />

                    <span asp-validation-for="NombreDeHabitacion" class="text-danger"></span>

                </div>

                <div class="col-md-4 mb-3">

                    <label asp-for="CantidadDeHuespedesPermitidos" class="form-label fw-bold"></label>

                    <input asp-for="CantidadDeHuespedesPermitidos" class="form-control" min="1" />

                    <span asp-validation-for="CantidadDeHuespedesPermitidos" class="text-danger"></span>

                </div>

                <div class="col-md-4 mb-3">

                    <label asp-for="CantidadDeCamas" class="form-label fw-bold"></label>

                    <input asp-for="CantidadDeCamas" class="form-control" min="1" />

                    <span asp-validation-for="CantidadDeCamas" class="text-danger"></span>

                </div>

                <div class="col-md-4 mb-3">

                    <label asp-for="CantidadDeBanos" class="form-label fw-bold"></label>

                    <input asp-for="CantidadDeBanos" class="form-control" min="1" />

                    <span asp-validation-for="CantidadDeBanos" class="text-danger"></span>

                </div>

                <div class="col-md-6 mb-3">

                    <label asp-for="Ubicacion" class="form-label fw-bold"></label>

                    <input asp-for="Ubicacion" class="form-control" />

                    <span asp-validation-for="Ubicacion" class="text-danger"></span>

                </div>

                <div class="col-md-6 mb-3">

                    <label asp-for="EncargadoDeLimpieza" class="form-label fw-bold"></label>

                    <input asp-for="EncargadoDeLimpieza" class="form-control" />

                    <span asp-validation-for="EncargadoDeLimpieza" class="text-danger"></span>

                </div>

                <div class="col-md-4 mb-3">

                    <label asp-for="TipoDeHabitacion" class="form-label fw-bold"></label>

                    <select asp-for="TipoDeHabitacion" class="form-select">

                        <option value="">Seleccione...</option>
                        <option value="1">Junior</option>
                        <option value="2">Superior</option>
                        <option value="3">Suite</option>

                    </select>

                    <span asp-validation-for="TipoDeHabitacion" class="text-danger"></span>

                </div>

                <div class="col-md-4 mb-3">

                    <label asp-for="CostoDeLimpieza" class="form-label fw-bold"></label>

                    <input asp-for="CostoDeLimpieza" class="form-control" step="0.01" />

                    <span asp-validation-for="CostoDeLimpieza" class="text-danger"></span>

                </div>

                <div class="col-md-4 mb-3">

                    <label asp-for="CostoDeReserva" class="form-label fw-bold"></label>

                    <input asp-for="CostoDeReserva" class="form-control" step="0.01" />

                    <span asp-validation-for="CostoDeReserva" class="text-danger"></span>

                </div>

                <div class="col-md-12">

                    <div class="form-check">

                        <input asp-for="Estado" class="form-check-input" />

                        <label asp-for="Estado" class="form-check-label">

                            Habitación Activa

                        </label>

                    </div>

                </div>

            </div>

            <hr />

            <div class="d-flex justify-content-end gap-2">

                <a asp-action="Index"
                   class="btn btn-secondary">

                    ← Cancelar

                </a>

                <button type="submit"
                        class="btn btn-success">

                    💾 Guardar Habitación

                </button>

            </div>

        </form>

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>

        document.getElementById("frmHabitacion")
        .addEventListener("submit", function () {

            const boton = this.querySelector("button[type='submit']");

            boton.disabled = true;

            boton.innerHTML =
                "⏳ Guardando...";

        });

    </script>

}