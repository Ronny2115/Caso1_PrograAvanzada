@model List<Caso1_PrograAvanzada.Entities.Habitacion>

@{
    ViewData["Title"] = "Habitaciones";
}

<div class="card shadow-sm mb-4">

    <div class="card-body d-flex justify-content-between align-items-center">

        <div>

            <h2 class="mb-1">🏨 Administración de Habitaciones</h2>

            <p class="text-muted mb-0">
                Gestión de habitaciones registradas en el sistema.
            </p>

        </div>

        <a asp-action="Create" class="btn btn-primary btn-lg">

            ➕ Nueva Habitación

        </a>

    </div>

</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">

        @TempData["Mensaje"]

        <button class="btn-close" data-bs-dismiss="alert"></button>

    </div>
}

<div class="card shadow-sm">

    <div class="card-body">

        <div class="table-responsive">

            <table class="table table-hover align-middle">

                <thead class="table-dark">

                    <tr>

                        <th>Código</th>

                        <th>Habitación</th>

                        <th>Huéspedes</th>

                        <th>Camas</th>

                        <th>Baños</th>

                        <th>Ubicación</th>

                        <th>Encargado</th>

                        <th>Tipo</th>

                        <th>Costo Reserva</th>

                        <th>Estado</th>

                        <th class="text-center">Acciones</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>

                                <strong>@item.CodigoDeHabitacion</strong>

                            </td>

                            <td>@item.NombreDeHabitacion</td>

                            <td>@item.CantidadDeHuespedesPermitidos</td>

                            <td>@item.CantidadDeCamas</td>

                            <td>@item.CantidadDeBanos</td>

                            <td>@item.Ubicacion</td>

                            <td>@item.EncargadoDeLimpieza</td>

                            <td>

                                <span class="badge bg-info text-dark">

                                    @item.TipoHabitacionTexto

                                </span>

                            </td>

                            <td>

                                @item.CostoDeReserva.ToString("C")

                            </td>

                            <td>

                                @if (item.Estado)
                                {
                                    <span class="badge bg-success">

                                        Activa

                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">

                                        Inactiva

                                    </span>
                                }

                            </td>

                            <td class="text-center">

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-warning btn-sm">

                                    ✏️ Editar

                                </a>

                                <a asp-action="Reservas"
                                   asp-route-id="@item.Id"
                                   class="btn btn-info btn-sm">

                                    📋 Reservas

                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>