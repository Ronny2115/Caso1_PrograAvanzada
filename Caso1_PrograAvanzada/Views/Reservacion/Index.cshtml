@model List<Caso1_PrograAvanzada.Entities.Habitacion>

@{
    ViewData["Title"] = "Reservaciones";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>

        <h2>📅 Reservaciones</h2>

        <p class="text-muted mb-0">
            Seleccione una habitación para registrar una nueva reservación.
        </p>

    </div>

    <a asp-action="Buscar"
       class="btn btn-outline-primary">

        🔍 Buscar Reservación

    </a>

</div>

<div class="row">

    @foreach (var item in Model)
    {
        <div class="col-lg-4 col-md-6 mb-4">

            <div class="card h-100 shadow-sm">

                <div class="card-header bg-primary text-white text-center">

                    <h5 class="mb-0">

                        @item.NombreDeHabitacion

                    </h5>

                </div>

                <div class="card-body">

                    <p>

                        <strong>🏷 Código:</strong>

                        @item.CodigoDeHabitacion

                    </p>

                    <p>

                        <strong>📍 Ubicación:</strong>

                        @item.Ubicacion

                    </p>

                    <p>

                        <strong>👤 Huéspedes:</strong>

                        @item.CantidadDeHuespedesPermitidos

                    </p>

                    <p>

                        <strong>🛏 Camas:</strong>

                        @item.CantidadDeCamas

                    </p>

                    <p>

                        <strong>🛁 Baños:</strong>

                        @item.CantidadDeBanos

                    </p>

                    <p>

                        <strong>🧹 Encargado:</strong>

                        @item.EncargadoDeLimpieza

                    </p>

                    <p>

                        <strong>🏨 Tipo:</strong>

                        <span class="badge bg-info text-dark">

                            @item.TipoHabitacionTexto

                        </span>

                    </p>

                    <p>

                        <strong>💲Costo Limpieza:</strong>

                        @item.CostoDeLimpieza.ToString("C")

                    </p>

                    <p>

                        <strong>💰Costo por Noche:</strong>

                        <span class="fw-bold text-success">

                            @item.CostoDeReserva.ToString("C")

                        </span>

                    </p>

                </div>

                <div class="card-footer bg-white">

                    <div class="d-grid">

                        <a asp-action="Create"
                           asp-route-idHabitacion="@item.Id"
                           class="btn btn-success">

                            📝 Reservar Habitación

                        </a>

                    </div>

                </div>

            </div>

        </div>
    }

</div>