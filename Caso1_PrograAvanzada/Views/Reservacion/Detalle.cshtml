@model Caso1_PrograAvanzada.Entities.Reservacion

@{
    ViewData["Title"] = "Detalle de Reservación";
}

<div class="card shadow">

    <div class="card-header bg-success text-white">

        <h3 class="mb-0">

            📋 Detalle de la Reservación

        </h3>

    </div>

    <div class="card-body">

        @if (TempData["Mensaje"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">

                @TempData["Mensaje"]

                <button class="btn-close"
                        data-bs-dismiss="alert">
                </button>

            </div>
        }

        <div class="row">

            <div class="col-md-6">

                <div class="card mb-4">

                    <div class="card-header bg-primary text-white">

                        👤 Información del Cliente

                    </div>

                    <div class="card-body">

                        <p><strong>Nombre:</strong> @Model.NombreDeLaPersona</p>

                        <p><strong>Identificación:</strong> @Model.Identificacion</p>

                        <p><strong>Teléfono:</strong> @Model.Telefono</p>

                        <p><strong>Correo:</strong> @Model.Correo</p>

                        <p><strong>Fecha Nacimiento:</strong> @Model.FechaNacimiento.ToString("dd/MM/yyyy")</p>

                        <p><strong>Dirección:</strong> @Model.Direccion</p>

                    </div>

                </div>

            </div>

            <div class="col-md-6">

                <div class="card mb-4">

                    <div class="card-header bg-warning">

                        📅 Información de la Reservación

                    </div>

                    <div class="card-body">

                        <p><strong>ID:</strong> @Model.Id</p>

                        <p><strong>Fecha Inicio:</strong> @Model.FechaInicioReserva.ToString("dd/MM/yyyy")</p>

                        <p><strong>Fecha Fin:</strong> @Model.FechaFinReserva.ToString("dd/MM/yyyy")</p>

                        <p><strong>Fecha Registro:</strong> @Model.FechaDeRegistro.ToString("dd/MM/yyyy HH:mm")</p>

                        <p>

                            <strong>Monto Total:</strong>

                            <span class="badge bg-success fs-6">

                                @Model.MontoTotal.ToString("C")

                            </span>

                        </p>

                        <p>

                            <strong>ID Habitación:</strong>

                            @Model.IdHabitacion

                        </p>

                    </div>

                </div>

            </div>

        </div>

        <div class="d-flex justify-content-end gap-2">

            <a asp-action="Buscar"
               class="btn btn-secondary">

                🔍 Buscar Otra

            </a>

            <a asp-action="Index"
               class="btn btn-primary">

                ← Regresar

            </a>

        </div>

    </div>

</div>