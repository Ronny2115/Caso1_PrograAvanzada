@model Caso1_PrograAvanzada.Entities.Reservacion

@{
    ViewData["Title"] = "Registrar Reservación";
}

<div class="card shadow">

    <div class="card-header bg-success text-white">

        <h3 class="mb-0">
            📅 Registrar Nueva Reservación
        </h3>

    </div>

    <div class="card-body">

        @if (ViewBag.Mensaje != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">

                @ViewBag.Mensaje

                <button class="btn-close"
                        data-bs-dismiss="alert">
                </button>

            </div>
        }

        <form asp-action="Create"
              method="post"
              id="frmReservacion">

            <input asp-for="IdHabitacion" type="hidden" />

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>

            <h5 class="mb-3 text-primary">

                👤 Información del Cliente

            </h5>

            <div class="row">

                <div class="col-md-6 mb-3">

                    <label asp-for="NombreDeLaPersona"
                           class="form-label fw-bold"></label>

                    <input asp-for="NombreDeLaPersona"
                           class="form-control" />

                    <span asp-validation-for="NombreDeLaPersona"
                          class="text-danger"></span>

                </div>

                <div class="col-md-6 mb-3">

                    <label asp-for="Identificacion"
                           class="form-label fw-bold"></label>

                    <input asp-for="Identificacion"
                           class="form-control" />

                    <span asp-validation-for="Identificacion"
                          class="text-danger"></span>

                </div>

                <div class="col-md-6 mb-3">

                    <label asp-for="Telefono"
                           class="form-label fw-bold"></label>

                    <input asp-for="Telefono"
                           class="form-control" />

                    <span asp-validation-for="Telefono"
                          class="text-danger"></span>

                </div>

                <div class="col-md-6 mb-3">

                    <label asp-for="Correo"
                           class="form-label fw-bold"></label>

                    <input asp-for="Correo"
                           class="form-control" />

                    <span asp-validation-for="Correo"
                          class="text-danger"></span>

                </div>

                <div class="col-md-6 mb-3">

                    <label asp-for="FechaNacimiento"
                           class="form-label fw-bold"></label>

                    <input asp-for="FechaNacimiento"
                           type="date"
                           class="form-control" />

                    <span asp-validation-for="FechaNacimiento"
                          class="text-danger"></span>

                </div>

            </div>

            <hr />

            <h5 class="mb-3 text-primary">

                🏨 Información de la Reservación

            </h5>

            <div class="row">

                <div class="col-md-6 mb-3">

                    <label asp-for="FechaInicioReserva"
                           class="form-label fw-bold"></label>

                    <input asp-for="FechaInicioReserva"
                           type="date"
                           class="form-control" />

                    <span asp-validation-for="FechaInicioReserva"
                          class="text-danger"></span>

                </div>

                <div class="col-md-6 mb-3">

                    <label asp-for="FechaFinReserva"
                           class="form-label fw-bold"></label>

                    <input asp-for="FechaFinReserva"
                           type="date"
                           class="form-control" />

                    <span asp-validation-for="FechaFinReserva"
                          class="text-danger"></span>

                </div>

                <div class="col-12 mb-3">

                    <label asp-for="Direccion"
                           class="form-label fw-bold"></label>

                    <textarea asp-for="Direccion"
                              rows="3"
                              class="form-control"></textarea>

                    <span asp-validation-for="Direccion"
                          class="text-danger"></span>

                </div>

            </div>

            <hr />

            <div class="d-flex justify-content-end gap-2">

                <a asp-action="Index"
                   class="btn btn-secondary">

                    ← Cancelar

                </a>

                <button type="submit"
                        class="btn btn-success">

                    💾 Registrar Reservación

                </button>

            </div>

        </form>

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>

        document.getElementById("frmReservacion")
            .addEventListener("submit", function () {

                const boton = this.querySelector("button[type='submit']");

                boton.disabled = true;

                boton.innerHTML = "⏳ Registrando...";

            });

    </script>

}