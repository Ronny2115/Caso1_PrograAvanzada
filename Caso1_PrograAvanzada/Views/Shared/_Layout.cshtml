<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Reservaciones</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Caso1_PrograAvanzada.styles.css" asp-append-version="true" />
</head>
<body>

    <header>

        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">

            <div class="container">

                <a class="navbar-brand"
                   asp-controller="Home"
                   asp-action="Index">

                    🏨 Sistema de Reservaciones

                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbar">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse"
                     id="navbar">

                    <ul class="navbar-nav ms-auto">

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">

                                Inicio

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Habitacion"
                               asp-action="Index">

                                Habitaciones

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Reservacion"
                               asp-action="Index">

                                Reservaciones

                            </a>

                        </li>

                    </ul>

                </div>

            </div>

        </nav>

    </header>

    <div class="container mt-4">

        <main role="main">

            @RenderBody()

        </main>

    </div>

    <footer class="border-top mt-5">

        <div class="container text-center py-3 text-muted">

            <small>

                © 2026 Sistema de Gestión de Habitaciones y Reservaciones |
                Programación Avanzada

            </small>

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>