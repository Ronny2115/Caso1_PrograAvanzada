@{
    ViewData["Title"] = "Inicio";
}

<div class="hero text-center mb-5">

    <h1 class="display-4 mb-3">
        🏨 Sistema de Gestión de Reservaciones
    </h1>

    <p class="lead text-muted">
        Administración de habitaciones y reservaciones del hotel.
    </p>

    <hr class="my-4" />

    <div class="d-flex justify-content-center gap-3 flex-wrap">

        <a asp-controller="Habitacion"
           asp-action="Index"
           class="btn btn-primary btn-lg">

            🛏 Administrar Habitaciones

        </a>

        <a asp-controller="Reservacion"
           asp-action="Index"
           class="btn btn-success btn-lg">

            📅 Administrar Reservaciones

        </a>

    </div>

</div>

<div class="row g-4">

    <div class="col-lg-4">

        <div class="card h-100 module-card">

            <div class="card-body text-center">

                <h1>🏨</h1>

                <h4 class="mt-3">

                    Habitaciones

                </h4>

                <p class="text-muted">

                    Crear, editar y administrar las habitaciones del hotel.

                </p>

                <a asp-controller="Habitacion"
                   asp-action="Index"
                   class="btn btn-outline-primary">

                    Ingresar

                </a>

            </div>

        </div>

    </div>

    <div class="col-lg-4">

        <div class="card h-100 module-card">

            <div class="card-body text-center">

                <h1>📅</h1>

                <h4 class="mt-3">

                    Reservaciones

                </h4>

                <p class="text-muted">

                    Registrar reservaciones y consultar su información.

                </p>

                <a asp-controller="Reservacion"
                   asp-action="Index"
                   class="btn btn-outline-success">

                    Ingresar

                </a>

            </div>

        </div>

    </div>

    <div class="col-lg-4">

        <div class="card h-100 module-card">

            <div class="card-body text-center">

                <h1>📋</h1>

                <h4 class="mt-3">

                    Caso Práctico

                </h4>

                <p class="text-muted">

                    Proyecto desarrollado en ASP.NET Core MVC utilizando arquitectura por capas.

                </p>

                <span class="badge bg-success fs-6">

                    Programación Avanzada

                </span>

            </div>

        </div>

    </div>

</div>

<div class="mt-5">

    <div class="card">

        <div class="card-body">

            <h4 class="mb-3">

                Funcionalidades del Sistema

            </h4>

            <div class="row">

                <div class="col-md-6">

                    <ul class="list-group list-group-flush">

                        <li class="list-group-item">
                            ✔ Registrar habitaciones
                        </li>

                        <li class="list-group-item">
                            ✔ Editar habitaciones
                        </li>

                        <li class="list-group-item">
                            ✔ Consultar habitaciones
                        </li>

                    </ul>

                </div>

                <div class="col-md-6">

                    <ul class="list-group list-group-flush">

                        <li class="list-group-item">
                            ✔ Registrar reservaciones
                        </li>

                        <li class="list-group-item">
                            ✔ Consultar reservaciones
                        </li>

                        <li class="list-group-item">
                            ✔ Validación de disponibilidad
                        </li>

                    </ul>

                </div>

            </div>

        </div>

    </div>

</div>