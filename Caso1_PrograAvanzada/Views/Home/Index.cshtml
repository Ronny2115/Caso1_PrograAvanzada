@{
    ViewData["Title"] = "Inicio";
}

<div class="container mt-5">

    <div class="text-center">

        <h1 class="display-4 fw-bold">
            Sistema de Gestión de Reservaciones
        </h1>

        <h3 class="text-secondary">
            Hotel Paradise
        </h3>

        <hr />

        <p class="lead">
            Bienvenido al sistema de administración de habitaciones y reservaciones.
        </p>

    </div>

    <br />

    <div class="row justify-content-center">

        <div class="col-md-5">

            <div class="card shadow">

                <div class="card-body text-center">

                    <h3>🏨 Habitaciones</h3>

                    <p>
                        Administración de habitaciones del hotel.
                    </p>

                    <a asp-controller="Habitacion"
                       asp-action="Index"
                       class="btn btn-primary">

                        Ir al módulo

                    </a>

                </div>

            </div>

        </div>

        <div class="col-md-5">

            <div class="card shadow">

                <div class="card-body text-center">

                    <h3>📅 Reservaciones</h3>

                    <p>
                        Gestión de reservaciones de clientes.
                    </p>

                    <a asp-controller="Reservacion"
                       asp-action="Index"
                       class="btn btn-success">

                        Ir al módulo

                    </a>

                </div>

            </div>

        </div>

    </div>

    <br />

    <div class="alert alert-info text-center">

        <strong>Curso:</strong> Programación Avanzada <br />

        <strong>Caso Práctico #1</strong><br />

        Sistema de Administración de Habitaciones y Reservaciones.

    </div>

</div>